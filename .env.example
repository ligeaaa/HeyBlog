# HeyBlog local defaults
HEYBLOG_DB_PATH=/file/path/heyblog.sqlite
HEYBLOG_SEED_PATH=/file/path/seed.csv
HEYBLOG_EXPORT_DIR=/file/path/exports
HEYBLOG_SEARCH_CACHE_DIR=/file/path/search-cache

# HeyBlog service URLs for host-machine development
HEYBLOG_BACKEND_BASE_URL=http://127.0.0.1:8000
HEYBLOG_CRAWLER_BASE_URL=http://127.0.0.1:8010
HEYBLOG_SEARCH_BASE_URL=http://127.0.0.1:8020
HEYBLOG_PERSISTENCE_BASE_URL=http://127.0.0.1:8030

# Docker-only internal service URLs
HEYBLOG_DOCKER_BACKEND_BASE_URL=http://backend:8000
HEYBLOG_DOCKER_CRAWLER_BASE_URL=http://crawler:8010
HEYBLOG_DOCKER_SEARCH_BASE_URL=http://search:8020
HEYBLOG_DOCKER_PERSISTENCE_BASE_URL=http://persistence-api:8030
HEYBLOG_DOCKER_SEED_PATH=/data/seeds/seed.csv
HEYBLOG_DOCKER_EXPORT_DIR=/data/exports
HEYBLOG_DOCKER_SEARCH_CACHE_DIR=/data/search-cache

# Ports
HEYBLOG_FRONTEND_PORT=3000
HEYBLOG_BACKEND_PORT=8000
HEYBLOG_CRAWLER_PORT=8010
HEYBLOG_SEARCH_PORT=8020
HEYBLOG_PERSISTENCE_API_PORT=8030
HEYBLOG_PERSISTENCE_DB_PORT=5432

# General runtime knobs
HEYBLOG_USER_AGENT=HeyBlogBot/0.1 (+https://example.invalid/heyblog)
HEYBLOG_REQUEST_TIMEOUT_SECONDS=10.0
HEYBLOG_MAX_NODES_PER_RUN=10
HEYBLOG_MAX_PATH_PROBES_PER_BLOG=50
HEYBLOG_CANDIDATE_PAGE_FETCH_CONCURRENCY=4
HEYBLOG_RUNTIME_WORKER_COUNT=3

# Optional crawler blocklists
HEYBLOG_FRIEND_LINK_DOMAIN_BLOCKLIST=
HEYBLOG_FRIEND_LINK_TLD_BLOCKLIST=
HEYBLOG_FRIEND_LINK_EXACT_URL_BLOCKLIST=
HEYBLOG_FRIEND_LINK_PREFIX_BLOCKLIST=

# Database
POSTGRES_DB=heyblog
POSTGRES_USER=heyblog
POSTGRES_PASSWORD=heyblog
HEYBLOG_DB_DSN=postgresql+psycopg://heyblog:heyblog@persistence-db:5432/heyblog

# Agent eval
# Default provider/model used when the CLI does not pass --provider / --model.
AGENT_DEFAULT_PROVIDER=deepseek
AGENT_DEFAULT_MODEL=deepseek-chat

# Provider credentials. Add one or more provider blocks.
AGENT_PROVIDER_DEEPSEEK_MODEL=deepseek-chat
AGENT_PROVIDER_DEEPSEEK_API_KEY=your_real_deepseek_api_key
AGENT_PROVIDER_DEEPSEEK_BASE_URL=https://api.deepseek.com

# Optional reasoning model example
# AGENT_PROVIDER_DEEPSEEK_MODEL=deepseek-reasoner

# Agent runtime knobs
AGENT_FETCH_MAX_CONCURRENCY=4
AGENT_CLASSIFICATION_MAX_CONCURRENCY=2
AGENT_CLASSIFICATION_REQUESTS_PER_MINUTE=60
AGENT_FETCH_TIMEOUT_SECONDS=10
AGENT_MAX_PAGE_BYTES=2000000
AGENT_OUTPUT_ROOT=/file/path/agent-evals
